# ===========================================
# LUMIRA V2 - Environment Variables
# ===========================================

# Database (PostgreSQL 16)
DATABASE_URL="postgresql://user:password@localhost:5432/lumira-v2?schema=public"

# ===========================================
# Authentication (REQUIRED - NO DEFAULTS)
# ===========================================
JWT_SECRET="generate-a-secure-64-char-secret-key-here"
# Sanctuaire/client JWT lifetime (also used by Next.js session cookie verification)
JWT_EXPIRATION="30d"
# Expert desk access-token lifetime
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="7d"

# ===========================================
# API Configuration
# ===========================================
PORT=3001
API_URL="http://localhost:3001"
WEB_URL="http://localhost:3000"
# Internal API address used by the Next.js server in Docker.
API_INTERNAL_URL="http://localhost:3001"
# Base64-encoded 32-byte key for encrypted admin credentials at rest.
SETTINGS_ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"

# Required to deliver Sanctuaire magic login links
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="smtp-user"
SMTP_PASS="smtp-password"
MAIL_FROM="noreply@example.com"
FRONTEND_URL="http://localhost:3000" # Legacy alias; WEB_URL is canonical.
NODE_ENV="development"

# ===========================================
# Desk production worker
# ===========================================
# The API owns long-running reading/audio jobs. Keep enabled on exactly one API
# replica until jobs are moved from Order.expertReview to a dedicated queue table.
PRODUCTION_WORKER_ENABLED="true"
PRODUCTION_WORKER_POLL_MS=2500
PRODUCTION_WORKER_CONCURRENCY=2
PRODUCTION_JOB_STALE_MS=900000
PRODUCTION_JOB_MAX_ATTEMPTS=3

# ===========================================
# Stripe Payments (REQUIRED for checkout)
# ===========================================
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-signing-secret"

# Product Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_INITIE="price_initie_id"
STRIPE_PRICE_MYSTIQUE="price_mystique_id"
STRIPE_PRICE_PROFOND="price_profond_id"
STRIPE_PRICE_INTEGRAL="price_integral_id"

# One-time lifetime-access price (used by the legacy checkout endpoint)
STRIPE_PRICE_29="price_xxxxxxxxxxxxxxxxxxxx"

# ===========================================
# AI / Gemini API (REQUIRED for readings)
# ===========================================
GEMINI_API_KEY="your-gemini-api-key-from-google-ai-studio"

# ===========================================
# OpenAI / ChatGPT (OPTIONAL — second AI provider)
# ===========================================
OPENAI_API_KEY="your-openai-api-key"

# ===========================================
# PDF Generation - Gotenberg
# ===========================================
GOTENBERG_URL="http://localhost:3002"

# ===========================================
# AWS S3 Storage (for PDF/assets)
# ===========================================
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="eu-west-3"
# Canonical private bucket for PDFs, audio and reading assets.
AWS_S3_BUCKET_NAME="lumira-readings"
# Separate private bucket for onboarding photos and user uploads.
AWS_UPLOADS_BUCKET_NAME="lumira-uploads"
# Legacy aliases below are read only for backward-compatible deployments.
AWS_LECTURES_BUCKET_NAME="lumira-readings"
AWS_S3_BUCKET_READINGS="lumira-readings"
S3_READING_BUCKET="lumira-readings"
S3_UPLOAD_BUCKET="lumira-uploads"

# ===========================================
# n8n Integration (webhooks)
# ===========================================
N8N_INSIGHTS_API_KEY="your-secure-n8n-api-key-here"
N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook"
N8N_CALLBACK_SECRET="a-distinct-hmac-secret-for-n8n-callbacks"

# ===========================================
# Google Cloud TTS (for audio generation)
# ===========================================
# Base64-encoded service account JSON (preferred)
GOOGLE_CLOUD_TTS_KEY_JSON=""
# Or set GOOGLE_APPLICATION_CREDENTIALS path
# Set to "true" to use Journey voices (higher quality, check FR availability)
TTS_USE_JOURNEY_VOICES="false"

# ===========================================
# Frontend URLs
# ===========================================
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
# Meta (Facebook) Pixel — optional. When set (build-time), tracks PageView,
# InitiateCheckout and Purchase for ads conversion optimization.
# NEXT_PUBLIC_META_PIXEL_ID="1234567890"

# ===========================================
# Observability (OPTIONAL)
# ===========================================
# SENTRY_DSN="https://your-sentry-dsn"
# NEXT_PUBLIC_SENTRY_DSN="https://your-sentry-dsn"
