generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE // Legacy field on User.subscriptionStatus
  TRIAL // Legacy field on User.subscriptionStatus
  // V2 Stripe-aligned statuses (used on Subscription model)
  PAST_DUE
  CANCELED
  EXPIRED
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  AWAITING_VALIDATION
  COMPLETED
  FAILED
  REFUNDED
}

enum ProductOrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ExpertRole {
  EXPERT
  ADMIN
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  REVISION_NEEDED
}

enum ValidationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum AudioVoice {
  MASCULINE
  FEMININE
}

enum DeliveryFormat {
  EMAIL
  WHATSAPP
}

enum FileType {
  FACE_PHOTO
  PALM_PHOTO
  AUDIO_READING
}

enum DeliveryStatus {
  PENDING
  SENDING
  SENT
  FAILED
}

/// Lifecycle of a versioned reading. A sealed version is immutable and is the
/// only content allowed to reach the PDF renderer or delivery channel.
enum ReadingVersionStatus {
  DRAFT
  SEALED
  REOPENED
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
}

enum ReadingIntakeStatus {
  DRAFT
  SEALED
}

enum ProductLevel {
  INITIE
  MYSTIQUE
  PROFOND
  INTEGRALE
}

enum PathActionType {
  MANTRA
  RITUAL
  JOURNALING
  MEDITATION
  REFLECTION
}

enum UserStatus {
  ACTIVE
  BANNED
  SUSPENDED
}

model User {
  id                 String             @id @default(cuid())
  refId              String?            @unique // Business ID: LUM-C-YY-XXXX
  email              String             @unique
  firstName          String
  lastName           String
  phone              String?
  dateOfBirth        DateTime?
  stripeCustomerId   String?            @unique
  subscriptionStatus SubscriptionStatus @default(INACTIVE)
  status             UserStatus         @default(ACTIVE)
  totalOrders        Int                @default(0)
  lastOrderAt        DateTime?
  notes              String?            @db.Text // Internal CRM notes
  tags               String[] // CRM tags for categorization
  source             String? // Acquisition source (organic, referral, etc.)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  profile       UserProfile?
  orders        Order[]
  spiritualPath SpiritualPath?
  chatSessions  ChatSession[]
  akashicRecord AkashicRecord?
  notifications Notification[]
  subscription  Subscription? // V2: Single-offer subscription
  dreams        Dream[] // V2: Dream journal entries
  sanctuaireLoginTokens SanctuaireLoginToken[]
  consents      ConsentRecord[]
  onboardingProgress OnboardingProgress?
  readingIntakes ReadingIntake[]

  @@index([email])
  @@index([refId])
  @@index([status])
  @@index([subscriptionStatus])
  @@index([createdAt(sort: Desc)])
}

/// Single-use magic links for Sanctuaire access. Only a SHA-256 digest of the
/// bearer token is persisted, so a database dump cannot be used to log in.
model SanctuaireLoginToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@index([expiresAt])
}

enum NotificationType {
  EXPERT_VALIDATION
  ORDER_COMPLETED
  CONTENT_READY
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  metadata  Json? // { expertName, orderId, orderNumber, etc. }
  read      Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt(sort: Desc)])
}

model UserProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id])
  birthDate        String?
  birthTime        String?
  birthPlace       String?
  specificQuestion String?   @db.Text
  objective        String?   @db.Text
  facePhotoUrl     String?
  palmPhotoUrl     String?
  highs            String?   @db.Text
  lows             String?   @db.Text
  strongSide       String?
  weakSide         String?
  strongZone       String?
  weakZone         String?
  deliveryStyle    String?
  pace             Int?
  ailments         String?   @db.Text
  fears            String?   @db.Text
  rituals          String?   @db.Text
  preferredVoice   AudioVoice? // Voix préférée pour le TTS (MASCULINE/FEMININE)
  profileCompleted Boolean   @default(false)
  submittedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Order {
  id                 String          @id @default(cuid())
  orderNumber        String          @unique
  userId             String
  user               User            @relation(fields: [userId], references: [id])
  userEmail          String
  userName           String?
  amount             Int
  currency           String          @default("eur")
  status             OrderStatus     @default(PENDING)
  paymentIntentId    String?
  stripeSessionId    String?
  paidAt             DateTime?
  formData           Json
  clientInputs       Json?
  /// New purchases require an order-scoped, client-sealed intake before production.
  /// Existing orders default to false and retain the legacy profile fallback.
  intakeRequired     Boolean         @default(false)
  expertPrompt       String?         @db.Text
  expertInstructions String?         @db.Text
  generatedContent   Json?
  errorLog           String?         @db.Text
  expertReview       Json?
  expertValidation   Json?
  revisionCount      Int             @default(0)
  deliveredAt        DateTime?
  deliveryMethod     DeliveryFormat?
  // V2: Subscription link
  subscriptionId     String? // Optional link to the Subscription that generated this order
  // Upsell tracking
  addons             Json? // Array of purchased addons: [{type: 'FORECAST_6M', amount: 2700, paidAt: Date}]
  upsellOfferedAt    DateTime? // When upsell was shown
  upsellAcceptedAt   DateTime? // When upsell was accepted
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  // Relations for interconnected ecosystem
  files          OrderFile[]
  readingVersions ReadingVersion[]
  deliveries     DeliveryRecord[]
  generatedSteps PathStep[] // Steps generated from this reading
  chatContexts   ChatSession[] // Chat sessions related to this order
  aiRuns         AiRun[]
  readingIntake  ReadingIntake?

  @@index([userId])
  @@index([userEmail])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@index([paymentIntentId])
  @@index([userId, status])
  @@index([userId, status, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@index([userEmail, status, paidAt(sort: Desc)])
}

/// Legal, versioned acceptance records. They are append-only so a later policy
/// revision never erases the evidence of the prior acceptance.
model ConsentRecord {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose    String
  version    String
  acceptedAt DateTime @default(now())
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  readingIntakes ReadingIntake[]

  @@unique([userId, purpose, version])
  @@index([userId, acceptedAt(sort: Desc)])
}

/// Server-side resume point for the Sanctuaire diagnostic. Browser storage is
/// only a best-effort offline cache and never the authoritative draft.
model OnboardingProgress {
  id          String           @id @default(cuid())
  userId      String           @unique
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentStep Int              @default(0)
  status      OnboardingStatus @default(IN_PROGRESS)
  data        Json
  completedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, updatedAt(sort: Desc)])
}

/// Canonical, order-scoped client material for one reading. Drafts remain
/// editable indefinitely; a SEALED row is immutable application data.
model ReadingIntake {
  id              String              @id @default(cuid())
  orderId         String              @unique
  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId          String
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          ReadingIntakeStatus @default(DRAFT)
  schemaVersion   String
  currentStep     Int                 @default(0)
  data            Json
  revision        Int                 @default(0)
  contentHash     String?
  sealedAt        DateTime?
  consentRecordId String?
  consentRecord   ConsentRecord?      @relation(fields: [consentRecordId], references: [id], onDelete: SetNull)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([userId, status, updatedAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@index([contentHash])
}

model ReadingVersion {
  id              String               @id @default(cuid())
  orderId         String
  order           Order                @relation(fields: [orderId], references: [id], onDelete: Cascade)
  version         Int
  status          ReadingVersionStatus @default(DRAFT)
  /// Immutable canonical payload rendered to PDF after an expert seal.
  content         Json
  contentHash     String
  source          String
  sealedByExpertId String?
  sealedAt        DateTime?
  reopenedAt      DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deliveries      DeliveryRecord[]

  @@unique([orderId, version])
  @@index([orderId, status, version(sort: Desc)])
  @@index([contentHash])
}

/// Persistent delivery ledger. It binds a private PDF object to the immutable
/// content hash and makes notification retries observable and idempotent.
model DeliveryRecord {
  id               String         @id @default(cuid())
  orderId          String
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  readingVersionId String
  readingVersion   ReadingVersion @relation(fields: [readingVersionId], references: [id], onDelete: Cascade)
  pdfKey           String
  contentHash      String
  emailStatus      DeliveryStatus @default(PENDING)
  emailAttempts    Int            @default(0)
  emailSentAt      DateTime?
  lastEmailError   String?        @db.Text
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([orderId, readingVersionId])
  @@index([emailStatus, updatedAt(sort: Desc)])
  @@index([contentHash])
}

model OrderFile {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  name        String
  url         String
  key         String
  contentType String
  size        Int
  type        FileType
  uploadedAt  DateTime @default(now())

  @@index([orderId])
  @@index([orderId, type])
}

model ProductOrder {
  id              String             @id @default(cuid())
  productId       String
  customerId      String?
  customerEmail   String?
  amount          Int
  currency        String             @default("eur")
  status          ProductOrderStatus @default(PENDING)
  paymentIntentId String             @unique
  completedAt     DateTime?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([productId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model Expert {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String
  role      ExpertRole @default(EXPERT)
  isActive  Boolean    @default(true)
  lastLogin DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([isActive])
  @@index([createdAt(sort: Desc)])
}

model ProcessedEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  eventType   String
  processedAt DateTime @default(now())
  data        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([eventId])
}

model Product {
  id           String       @id
  name         String
  description  String
  amountCents  Int
  currency     String       @default("eur")
  level        ProductLevel
  features     String[]
  limitedOffer String?
  isActive     Boolean      @default(true)
  comingSoon   Boolean      @default(false)
  metadata     Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

// =============================================================================
// INSIGHTS - AI-Generated Spiritual Insights
// =============================================================================

enum InsightCategory {
  SPIRITUEL
  RELATIONS
  MISSION
  CREATIVITE
  EMOTIONS
  TRAVAIL
  SANTE
  FINANCE
}

model Insight {
  id        String          @id @default(cuid())
  userId    String
  orderId   String?
  category  InsightCategory
  short     String          @db.Text // Résumé court (2-3 phrases)
  full      String          @db.Text // Texte complet (1-2 paragraphes)
  audioUrl  String?         // URL S3 du fichier audio TTS
  viewedAt  DateTime? // Null = "Nouveau" badge
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  dreams Dream[] // V2: Dreams linked to this insight domain

  @@unique([userId, category]) // Un seul insight par catégorie par user
  @@index([userId])
  @@index([orderId])
}

// =============================================================================
// DIGITAL SOUL - Spiritual Path & Journey
// =============================================================================

model SpiritualPath {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  archetype   String // e.g., "Le Guérisseur", "Le Visionnaire"
  synthesis   String    @db.Text // AI-generated synthesis of the user's spiritual journey
  keyBlockage String? // Primary spiritual blockage identified
  monthNumber Int       @default(1) // V2: Which subscription month this path covers (1, 2, 3...)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  steps PathStep[]

  @@index([userId])
  @@index([archetype])
}

model PathStep {
  id              String         @id @default(cuid())
  spiritualPathId String
  spiritualPath   SpiritualPath  @relation(fields: [spiritualPathId], references: [id], onDelete: Cascade)
  dayNumber       Int // Day in the journey (1-30, etc.)
  title           String // Step title
  description     String         @db.Text // Detailed description of this step
  synthesis       String         @db.Text // AI-generated content for this step
  archetype       String // Archetype theme for this step
  actionType      PathActionType @default(REFLECTION) // Type of action required
  ritualPrompt    String?        @db.Text // Optional ritual/meditation prompt
  isCompleted     Boolean        @default(false)
  completedAt     DateTime?
  unlockedAt      DateTime? // When this step became available
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Link back to the reading that generated this step
  originReadingId String?
  originReading   Order?  @relation(fields: [originReadingId], references: [id], onDelete: SetNull)
  dreams          Dream[] // V2: Dreams submitted on this day

  @@unique([spiritualPathId, dayNumber])
  @@index([spiritualPathId])
  @@index([dayNumber])
  @@index([isCompleted])
  @@index([originReadingId])
}

// =============================================================================
// CHAT - Conversational AI Sessions
// =============================================================================

model ChatSession {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  relatedOrderId String? // Optional link to a specific reading
  relatedOrder   Order?    @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)
  title          String? // Auto-generated session title
  messages       Json      @default("[]") // Array of {role, content, timestamp}
  isActive       Boolean   @default(true)
  lastMessageAt  DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([relatedOrderId])
  @@index([isActive])
  @@index([lastMessageAt(sort: Desc)])
}

// =============================================================================
// SYSTEM SETTINGS - Dynamic Configuration
// =============================================================================

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   @db.Text
  isEncrypted Boolean  @default(false)
  updatedAt   DateTime @updatedAt
}

// =============================================================================
// PROMPT VERSIONS - AI Prompt History & Versioning
// =============================================================================

model PromptVersion {
  id        String   @id @default(cuid())
  key       String // LUMIRA_DNA, SCRIBE, GUIDE, EDITOR, CONFIDANT, MODEL_CONFIG
  version   Int // Auto-incrementing per key
  value     String   @db.Text // The prompt content or JSON config
  changedBy String? // Expert email who made the change
  comment   String? // Optional change note
  isActive  Boolean  @default(false) // Only one active per key
  createdAt DateTime @default(now())

  routingRules AiRoutingRule[] // Rules that pin a specific prompt version

  @@unique([key, version])
  @@index([key, isActive])
  @@index([key, createdAt])
}

// =============================================================================
// AKASHIC RECORDS - User's Spiritual Memory & Context
// =============================================================================

model AkashicRecord {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core spiritual identity
  archetype String? // Primary archetype (e.g., "Le Guérisseur", "Le Visionnaire")

  // Structured spiritual data
  domains Json @default("{}") // { "relations": {...}, "mission": {...}, "sante": {...}, ... }

  // Conversation & interaction history summary
  history Json @default("[]") // Array of { date, topic, insights, sentiment }

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([archetype])
}

// =============================================================================
// V2 - SUBSCRIPTION — Single-offer 29€/month model
// =============================================================================

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  stripeSubscriptionId String             @unique
  stripeCustomerId     String
  stripePriceId        String
  status               SubscriptionStatus @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([userId])
  @@index([stripeSubscriptionId])
  @@index([status])
  @@index([currentPeriodEnd])
}

// =============================================================================
// V2 - DREAMS — Oniric journal & interpretation (agent ONIRIQUE)
// =============================================================================

model Dream {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  content         String    @db.Text // Raw dream text written by the user (20-2000 chars)
  emotion         String? // Optional emotion tag: paix, peur, joie, confusion, tristesse...
  interpretation  String    @db.Text // Full structured response from the ONIRIQUE agent (JSON string)
  symbols         String[] // Auto-detected symbols: ["eau", "escalier", "lumière"]
  linkedInsightId String? // Optional link to a spiritual insight domain
  linkedInsight   Insight?  @relation(fields: [linkedInsightId], references: [id], onDelete: SetNull)
  linkedStepId    String? // Optional link to the PathStep active on the day of the dream
  linkedStep      PathStep? @relation(fields: [linkedStepId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([linkedInsightId])
  @@index([linkedStepId])
}

// =============================================================================
// SEQUENCE COUNTERS - For Business ID Generation
// =============================================================================

model SequenceCounter {
  id        String   @id @default(cuid())
  name      String   @unique // e.g., "client_2026", "order_20260127"
  value     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@index([name])
}

// =============================================================================
// AI ROUTING MATRIX - [ProductLevel] x [Agent] x [Mission] -> Provider + Model
// =============================================================================

enum AiMission {
  DEFAULT // Fallback universel (s’applique si aucune règle plus spécifique)
  READING_GENERATION // SCRIBE → génération lecture PDF
  TIMELINE_BATCH // GUIDE → batch 30 jours
  DREAM_INTERPRETATION // ONIRIQUE → interprétation rêve
  CHAT_SESSION // CONFIDANT → session chat
  CONTENT_REFINEMENT // EDITOR → affinage expert
  AUDIO_NARRATION // NARRATOR → script TTS
}

model AiRoutingRule {
  id              String       @id @default(cuid())
  productLevel    ProductLevel // INITIE | MYSTIQUE | PROFOND | INTEGRALE
  agent           String // SCRIBE | GUIDE | EDITOR | CONFIDANT | ONIRIQUE | NARRATOR
  mission         AiMission    @default(DEFAULT)
  provider        String       @default("gemini") // "gemini" | "openai"
  model           String // ex: "gemini-2.5-flash", "gpt-4o"
  temperature     Float        @default(0.8)
  maxTokens       Int          @default(16384)
  promptVersionId String? // FK optionnel vers PromptVersion (prompt spécifique)
  promptVersion   PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)
  isActive        Boolean      @default(true)
  note            String?      @db.Text // Note admin
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@unique([productLevel, agent, mission])
  @@index([productLevel])
  @@index([agent])
  @@index([isActive])
}

enum AiRunStatus {
  SUCCESS
  ERROR
}

model AiRun {
  id              String        @id @default(cuid())
  orderId         String?
  order           Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  agent           String
  mission         AiMission
  productLevel    ProductLevel?
  provider        String
  model           String
  promptVersionId String?
  routingSource   String?
  startedAt       DateTime      @default(now())
  completedAt     DateTime?
  durationMs      Int?
  status          AiRunStatus
  errorCode       String?
  inputTokens     Int?
  outputTokens    Int?
  estimatedCost   Float?
  createdAt       DateTime      @default(now())

  @@index([orderId])
  @@index([agent, mission])
  @@index([startedAt(sort: Desc)])
}
