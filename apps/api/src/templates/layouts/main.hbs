<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{title}}</title>
  <style>
    @page {
      size: A4;
      margin: 15mm 16mm 19mm;
    }

    :root {
      --ink: #25223a;
      --ink-soft: #625d76;
      --paper: #fffcf7;
      --lavender: #f0eafd;
      --lavender-deep: #5c4589;
      --plum: #33264f;
      --gold: #b78235;
      --gold-soft: #f4e6ca;
      --line: #ded6e9;
    }

    * { box-sizing: border-box; }

    html, body { margin: 0; padding: 0; }

    body {
      background: var(--paper);
      color: var(--ink);
      font-family: "Aptos", "Segoe UI", Arial, sans-serif;
      font-size: 10.5pt;
      line-height: 1.68;
      -webkit-print-color-adjust: exact;
      print-color-adjust: exact;
    }

    h1, h2, h3, h4, p { margin: 0; }

    h1, h2, h3, h4 {
      color: var(--plum);
      font-family: Georgia, "Times New Roman", serif;
      font-weight: 400;
    }

    a { color: inherit; text-decoration: none; }

    .document-shell { position: relative; }

    .running-footer {
      position: fixed;
      bottom: -12mm;
      left: 0;
      right: 0;
      display: flex;
      justify-content: space-between;
      color: var(--ink-soft);
      font-size: 7.5pt;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .running-footer__mark { color: var(--lavender-deep); font-weight: 700; }

    .page-break { break-after: page; page-break-after: always; }
    .avoid-break { break-inside: avoid; page-break-inside: avoid; }

    @media print {
      .running-footer { display: flex; }
    }
  </style>
</head>
<body>
  <main class="document-shell">
    {{{body}}}
  </main>
  <div class="running-footer" aria-hidden="true">
    <span class="running-footer__mark">Lumira</span>
    <span>Lecture personnelle · {{userName}}</span>
  </div>
</body>
</html>
