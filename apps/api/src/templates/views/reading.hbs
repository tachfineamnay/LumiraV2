{{!-- The body is deliberately editorial: navigable chapters, short synthesis blocks,
      and practical rituals. All free-form prose is passed through richText. --}}

<section class="cover page-break">
  <div class="cover__halo cover__halo--one"></div>
  <div class="cover__halo cover__halo--two"></div>
  <div class="cover__eyebrow">Lecture d'âme personnelle</div>
  <div class="cover__rule"><span></span><i>✦</i><span></span></div>
  <h1>Une lecture<br>pour vous retrouver.</h1>
  <p class="cover__lead">Un espace pour écouter les motifs qui se répètent, éclairer ce qui demande votre attention et avancer avec plus de présence.</p>
  <div class="cover__recipient">
    <span>Préparée pour</span>
    <strong>{{userName}}</strong>
  </div>
  <div class="cover__meta">
    <span>{{formatDate generatedAt}}</span>
    <span>Oracle Lumira</span>
  </div>
</section>

<section class="orientation page-break">
  <p class="kicker">Votre repère</p>
  <h2>Comment parcourir votre lecture</h2>
  <p class="orientation__intro">Commencez par l'essentiel, puis avancez à votre rythme dans les chapitres qui résonnent le plus aujourd'hui. Revenez-y avec un carnet : les passages qui vous touchent sont souvent les plus utiles à explorer.</p>

  <div class="essence-card avoid-break">
    <div>
      <p class="card-label">Votre archétype</p>
      <h3>{{archetype}}</h3>
      {{#if archetypeDescription}}<div class="essence-card__description">{{{richText archetypeDescription}}}</div>{{/if}}
    </div>
    <div class="essence-card__symbol">✦</div>
  </div>

  {{#if keywords.length}}
  <div class="keywords avoid-break">
    <p class="card-label">Mots à garder en tête</p>
    <div class="keywords__list">
      {{#each keywords}}<span>{{this}}</span>{{/each}}
    </div>
  </div>
  {{/if}}

  <div class="toc">
    <p class="card-label">Dans cette lecture</p>
    {{#if introduction}}<a href="#message" class="toc__item"><b>01</b><span>Le message d'ouverture</span><i>→</i></a>{{/if}}
    {{#each sections}}<a href="#chapter-{{@index}}" class="toc__item"><b>{{sectionNumber @index @root.introduction}}</b><span>{{title}}</span><i>→</i></a>{{/each}}
    {{#if karmicInsights.length}}<a href="#insights" class="toc__item"><b>✦</b><span>Les repères profonds</span><i>→</i></a>{{/if}}
    {{#if lifeMission}}<a href="#mission" class="toc__item"><b>✦</b><span>Votre cap</span><i>→</i></a>{{/if}}
    {{#if rituals.length}}<a href="#rituals" class="toc__item"><b>✦</b><span>Vos pratiques</span><i>→</i></a>{{/if}}
    {{#if conclusion}}<a href="#closing" class="toc__item"><b>✦</b><span>Pour continuer</span><i>→</i></a>{{/if}}
  </div>

  {{#if birthData.date}}
  <div class="birth-note">
    <span>Lecture ancrée dans vos informations de naissance</span>
    <strong>{{birthData.date}}{{#if birthData.time}} · {{birthData.time}}{{/if}}{{#if birthData.place}} · {{birthData.place}}{{/if}}</strong>
  </div>
  {{/if}}
</section>

{{#if introduction}}
<section id="message" class="chapter page-break">
  <div class="chapter__header">
    <span>01</span><div><p class="kicker">Entrer dans la lecture</p><h2>Le message d'ouverture</h2></div>
  </div>
  <div class="prose prose--opening">{{{richText introduction}}}</div>
  <aside class="reading-prompt avoid-break"><span>À noter</span><p>Quelle phrase vous accompagne le plus après cette première lecture ?</p></aside>
</section>
{{/if}}

{{#each sections}}
<section id="chapter-{{@index}}" class="chapter page-break">
  <div class="chapter__header">
    <span>{{sectionNumber @index @root.introduction}}</span>
    <div><p class="kicker">{{capitalize domain}}</p><h2>{{title}}</h2></div>
  </div>
  <div class="prose">{{{richText content}}}</div>
  <aside class="chapter__anchor avoid-break"><span>Point d'ancrage</span><p>Relisez ce chapitre lentement et choisissez un geste simple qui lui donne une place dans votre semaine.</p></aside>
</section>
{{/each}}

{{#if karmicInsights.length}}
<section id="insights" class="focus-page page-break">
  <p class="kicker">À contempler</p>
  <h2>Les repères profonds</h2>
  <p class="focus-page__intro">Ces points ne sont pas des verdicts. Prenez-les comme des invitations à observer ce qui se joue avec douceur et curiosité.</p>
  <div class="insight-list">
    {{#each karmicInsights}}
    <article class="insight-card avoid-break"><span>{{inc @index}}</span><div>{{{richText this}}}</div></article>
    {{/each}}
  </div>
</section>
{{/if}}

{{#if lifeMission}}
<section id="mission" class="focus-page page-break">
  <p class="kicker">Votre direction</p>
  <h2>Votre cap</h2>
  <div class="mission-card">
    <div class="mission-card__mark">✦</div>
    <div class="prose">{{{richText lifeMission}}}</div>
  </div>
  <aside class="reading-prompt avoid-break"><span>À noter</span><p>Quel choix, même discret, pourrait honorer ce cap dans les sept prochains jours ?</p></aside>
</section>
{{/if}}

{{#if rituals.length}}
<section id="rituals" class="practice-page page-break">
  <p class="kicker">Mettre en mouvement</p>
  <h2>Vos pratiques</h2>
  <p class="practice-page__intro">Choisissez une pratique à la fois. La régularité compte davantage que l'intensité.</p>
  {{#each rituals}}
  <article class="ritual-card avoid-break">
    <div class="ritual-card__number">{{inc @index}}</div>
    <div class="ritual-card__body">
      <h3>{{name}}</h3>
      <div class="ritual-card__description">{{{richText description}}}</div>
      {{#if instructions.length}}
      <ol>{{#each instructions}}<li>{{this}}</li>{{/each}}</ol>
      {{/if}}
    </div>
  </article>
  {{/each}}
</section>
{{/if}}

{{#if conclusion}}
<section id="closing" class="closing">
  <p class="kicker">Pour continuer</p>
  <h2>Gardez ce qui vous éclaire</h2>
  <div class="closing__message">{{{richText conclusion}}}</div>
  <div class="closing__seal"><span>✦</span><p>Votre lecture est un point de départ.<br>Elle s'approfondit au fil de vos choix.</p></div>
</section>
{{/if}}

<style>
  .cover { min-height: 255mm; padding: 23mm 14mm 14mm; position: relative; overflow: hidden; background: var(--plum); color: #fffaf0; display: flex; flex-direction: column; align-items: center; text-align: center; }
  .cover__halo { position: absolute; border: 1px solid rgba(255,255,255,.16); border-radius: 50%; pointer-events: none; }
  .cover__halo--one { width: 220mm; height: 220mm; top: -90mm; right: -98mm; }
  .cover__halo--two { width: 145mm; height: 145mm; bottom: -78mm; left: -78mm; }
  .cover__eyebrow, .kicker, .card-label { color: var(--lavender-deep); font-size: 8pt; font-weight: 700; letter-spacing: .16em; text-transform: uppercase; }
  .cover__eyebrow { color: #dfd0ff; position: relative; }
  .cover__rule { display: flex; align-items: center; gap: 9px; margin: 27mm 0 12mm; color: #e8c984; position: relative; }
  .cover__rule span { width: 34mm; height: 1px; background: rgba(232,201,132,.65); }
  .cover h1 { color: #fffaf0; font-size: 38pt; line-height: 1.03; letter-spacing: -.035em; position: relative; }
  .cover__lead { max-width: 110mm; margin-top: 11mm; color: #eee7fb; font-family: Georgia, serif; font-size: 14pt; line-height: 1.5; position: relative; }
  .cover__recipient { margin-top: auto; position: relative; }
  .cover__recipient span { display: block; color: #d9cbea; font-size: 8pt; letter-spacing: .15em; text-transform: uppercase; }
  .cover__recipient strong { display: block; margin-top: 3mm; font-family: Georgia, serif; font-size: 22pt; font-weight: 400; }
  .cover__meta { width: 100%; display: flex; justify-content: space-between; margin-top: 24mm; color: #cfc3df; font-size: 8pt; letter-spacing: .08em; }

  .orientation, .focus-page, .practice-page, .closing { padding: 8mm 1mm 0; }
  .orientation h2, .focus-page h2, .practice-page h2, .closing h2 { margin-top: 3mm; font-size: 28pt; line-height: 1.1; letter-spacing: -.025em; }
  .orientation__intro, .focus-page__intro, .practice-page__intro { max-width: 142mm; margin-top: 7mm; color: var(--ink-soft); font-family: Georgia, serif; font-size: 13pt; line-height: 1.6; }
  .essence-card { display: flex; justify-content: space-between; gap: 12mm; margin-top: 12mm; padding: 10mm; background: var(--lavender); border-radius: 4mm; }
  .essence-card h3 { margin-top: 1.5mm; font-size: 25pt; line-height: 1.15; }
  .essence-card__description p { margin-top: 4mm; color: var(--ink-soft); font-family: Georgia, serif; font-size: 12pt; }
  .essence-card__symbol { align-self: flex-start; color: var(--gold); font-size: 26pt; }
  .keywords { margin-top: 8mm; }
  .keywords__list { display: flex; flex-wrap: wrap; gap: 2.5mm; margin-top: 3mm; }
  .keywords__list span { padding: 1.6mm 3.3mm; border: 1px solid var(--line); border-radius: 99px; color: var(--lavender-deep); font-size: 9pt; }
  .toc { margin-top: 11mm; border-top: 1px solid var(--line); }
  .toc .card-label { margin-top: 5mm; }
  .toc__item { display: grid; grid-template-columns: 10mm 1fr 8mm; gap: 3mm; align-items: center; min-height: 10mm; border-bottom: 1px solid var(--line); }
  .toc__item b { color: var(--gold); font-size: 8pt; letter-spacing: .06em; }
  .toc__item span { font-family: Georgia, serif; font-size: 12pt; }
  .toc__item i { color: var(--lavender-deep); font-size: 13pt; font-style: normal; text-align: right; }
  .birth-note { display: flex; justify-content: space-between; gap: 8mm; margin-top: 9mm; padding-top: 5mm; border-top: 1px solid var(--line); color: var(--ink-soft); font-size: 8.5pt; }
  .birth-note strong { color: var(--ink); font-weight: 600; text-align: right; }

  .chapter { padding: 7mm 1mm 0; }
  .chapter__header { display: grid; grid-template-columns: 16mm 1fr; gap: 5mm; align-items: start; padding-bottom: 7mm; border-bottom: 1px solid var(--line); }
  .chapter__header > span { display: grid; width: 12mm; height: 12mm; place-items: center; border-radius: 50%; background: var(--plum); color: #fff; font-size: 8.5pt; font-weight: 700; }
  .chapter h2 { margin-top: 1.5mm; font-size: 27pt; line-height: 1.1; letter-spacing: -.025em; }
  .prose { max-width: 151mm; margin-top: 9mm; font-family: Georgia, "Times New Roman", serif; font-size: 12.2pt; line-height: 1.75; }
  .prose--opening { font-size: 13pt; }
  .prose p + p { margin-top: 5mm; }
  .chapter__anchor, .reading-prompt { display: grid; grid-template-columns: 27mm 1fr; gap: 5mm; margin-top: 10mm; padding: 5.5mm 6mm; border-left: 2px solid var(--gold); background: #fff8ed; }
  .chapter__anchor span, .reading-prompt span { color: var(--gold); font-size: 8pt; font-weight: 700; letter-spacing: .13em; text-transform: uppercase; }
  .chapter__anchor p, .reading-prompt p { color: var(--ink-soft); font-family: Georgia, serif; font-size: 11pt; line-height: 1.45; }

  .focus-page__intro { margin-bottom: 9mm; }
  .insight-list { display: grid; gap: 4mm; }
  .insight-card { display: grid; grid-template-columns: 13mm 1fr; gap: 4mm; padding: 6mm; border: 1px solid var(--line); border-radius: 2mm; }
  .insight-card > span { color: var(--gold); font-family: Georgia, serif; font-size: 18pt; }
  .insight-card p { color: var(--ink-soft); font-family: Georgia, serif; font-size: 11.5pt; }
  .insight-card p + p { margin-top: 3mm; }
  .mission-card { display: grid; grid-template-columns: 20mm 1fr; gap: 5mm; margin-top: 10mm; padding: 11mm; border-radius: 4mm; background: var(--plum); }
  .mission-card .prose { margin: 0; color: #fffaf5; }
  .mission-card__mark { color: #e8c984; font-size: 19pt; }

  .ritual-card { display: grid; grid-template-columns: 15mm 1fr; gap: 5mm; padding: 7mm 0; border-bottom: 1px solid var(--line); }
  .ritual-card__number { display: grid; place-items: center; width: 10mm; height: 10mm; border-radius: 50%; background: var(--lavender); color: var(--lavender-deep); font-size: 8.5pt; font-weight: 700; }
  .ritual-card h3 { font-size: 17pt; line-height: 1.2; }
  .ritual-card__description { margin-top: 3mm; color: var(--ink-soft); font-family: Georgia, serif; font-size: 11.5pt; }
  .ritual-card__description p + p { margin-top: 3mm; }
  .ritual-card ol { margin: 4mm 0 0 5mm; padding-left: 5mm; color: var(--ink); }
  .ritual-card li { margin-top: 2mm; padding-left: 2mm; }
  .ritual-card li::marker { color: var(--gold); font-weight: 700; }

  .closing { min-height: 225mm; display: flex; flex-direction: column; align-items: center; text-align: center; }
  .closing h2 { max-width: 125mm; }
  .closing__message { max-width: 135mm; margin-top: 14mm; color: var(--ink-soft); font-family: Georgia, serif; font-size: 15pt; line-height: 1.7; }
  .closing__message p + p { margin-top: 5mm; }
  .closing__seal { margin-top: auto; padding-top: 15mm; color: var(--lavender-deep); }
  .closing__seal span { display: block; color: var(--gold); font-size: 24pt; }
  .closing__seal p { margin-top: 4mm; font-family: Georgia, serif; font-size: 12pt; line-height: 1.55; }
</style>
